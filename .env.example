# momo-anonymous-decision 服务端配置示例
# 复制为 .env 后按需修改（server/config.js 会自动读取项目根目录的 .env，无需 dotenv 依赖）
# 线上部署时通过环境变量或 .env 注入。

# 中转服务端口
PORT=8080

# 图片 URL 公网基地址（客户端据此拼接图片绝对地址）
# 本地开发留空即可（自动推导为 http://localhost:${PORT}）
# 线上预留子域名：
PUBLIC_URL=https://api-mosaic.m0m0n1.top

# 图片存活时长（小时），超过后定时任务物理删除
MAX_AGE_HOURS=24

# 硅基流动 SiliconFlow API Key —— 后端接力 STT（语音转文字）使用
# 获取：https://cloud.siliconflow.cn/ → API 密钥
# 模型 FunAudioLLM/SenseVoice-Small，调用 https://api.siliconflow.cn/v1/audio/transcriptions
SILICONFLOW_API_KEY=sk-在此填入你的Key
