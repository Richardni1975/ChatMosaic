/* pages/room/index.wxss — 三段式 + Phase 3 可视化信任（赛博朋克 / 极客简洁）
   尺寸统一用 rpx（750rpx = 屏幕宽），随屏幕宽度自适应；高度用 100% 避免 100vh 移动端溢出。 */

.room {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--bg);
  color: var(--text);
}

/* ===================== Zone 1 ===================== */

.zone-1 {
  flex: 0 0 65%;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

/* 房间码入口 */
.room-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  background: var(--card);
}
.room-label {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--accent);
  font-family: "SF Mono", "Consolas", monospace;
}
.room-input {
  width: 160rpx;
  height: 48rpx;
  text-align: center;
  font-size: 30rpx;
  letter-spacing: 12rpx;
  color: var(--accent);
  background: var(--bg);
  border: 1rpx solid var(--border);
  border-radius: 10rpx;
  font-family: "SF Mono", "Consolas", monospace;
}
.room-hint { font-size: 20rpx; color: var(--aux); }

/* ---- Phase 4：抗追踪混淆能量 / 网络脉冲 ---- */
.noise-strip {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  background: var(--card);
  overflow: hidden;
}

.noise-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 50%, rgba(16, 185, 129, 0.35), transparent 70%);
  pointer-events: none;
  transition: opacity 0.2s ease;
}

.noise-label {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--accent);
  font-family: "SF Mono", "Consolas", monospace;
  z-index: 1;
}

.wave {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 36rpx;
  z-index: 1;
}

.wave-bar {
  flex: 1;
  min-height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
  box-shadow: 0 0 8rpx rgba(16, 185, 129, 0.6);
  transition: height 0.16s ease;
}

.noise-val {
  font-size: 22rpx;
  color: var(--accent);
  font-family: "SF Mono", "Consolas", monospace;
  min-width: 68rpx;
  text-align: right;
  z-index: 1;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-chip {
  flex: 0 0 auto;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: var(--aux);
  background: var(--card);
  border: 1rpx solid var(--border);
  border-radius: 999rpx;
}

.filter-chip.active {
  color: #04110c;
  background: var(--accent);
  border-color: var(--accent);
  box-shadow: 0 0 24rpx rgba(16, 185, 129, 0.45);
}

.filter-chip.ghost {
  color: var(--accent);
  border-color: var(--accent);
}

.card-flow {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
}

.empty {
  padding: 96rpx 32rpx;
  text-align: center;
  color: var(--aux);
  font-size: 28rpx;
}

.card {
  background: var(--card);
  border: 1rpx solid var(--border);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

/* 进行中卡片：虚线边 + 微光 */
.card.collecting,
.card.assembling {
  border: 1rpx dashed var(--accent);
  background: linear-gradient(180deg, rgba(16,185,129,0.06), var(--card));
}

/* ---- 状态 1：拼图收集中 ---- */
.collect-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 16rpx var(--accent);
  animation: pulse 1.1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(1.4); }
}

.collect-status {
  font-size: 26rpx;
  color: var(--accent);
  font-family: "SF Mono", "Consolas", monospace;
  letter-spacing: 1rpx;
}

.collect-status.center {
  display: block;
  text-align: center;
  margin-top: 20rpx;
}

.hash-tag {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--aux);
  font-family: "SF Mono", "Consolas", monospace;
  opacity: 0.8;
}

.shard-row {
  display: flex;
  gap: 16rpx;
}

.shard-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  background: var(--bg);
}

.shard-chip.filled {
  border-color: var(--accent);
  background: rgba(16, 185, 129, 0.08);
  animation: slot-pop 0.4s ease both;
}

.shard-chip.empty {
  opacity: 0.45;
}

@keyframes slot-pop {
  0% { transform: translateY(-12rpx) scale(0.8); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

.ch-label {
  font-size: 20rpx;
  color: var(--aux);
  font-family: "SF Mono", "Consolas", monospace;
  letter-spacing: 1rpx;
}

.pv {
  font-size: 26rpx;
  color: var(--accent);
  font-family: "SF Mono", "Consolas", monospace;
  font-weight: 600;
}

.shard-chip.empty .pv {
  color: var(--aux);
  letter-spacing: 4rpx;
}

/* ---- 状态 2：拼图合体 ---- */
.merge-stage {
  position: relative;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.merge-frag {
  position: absolute;
  font-size: 26rpx;
  color: var(--accent);
  font-family: "SF Mono", "Consolas", monospace;
  font-weight: 600;
  text-shadow: 0 0 12rpx rgba(16, 185, 129, 0.6);
  /* 4 个碎片从四角向中心聚拢，按 --i 错峰 */
  animation: merge-in 0.7s cubic-bezier(0.6, 0, 0.2, 1) both;
  animation-delay: calc(var(--i) * 60ms);
}

@keyframes merge-in {
  0% {
    opacity: 0;
    transform: translate(calc((var(--i) - 1.5) * 80rpx), calc((var(--i) - 1.5) * 52rpx)) scale(0.7);
  }
  60% { opacity: 1; transform: translate(0, 0) scale(1.15); }
  100% { opacity: 0; transform: translate(0, 0) scale(0.4); }
}

.merge-core {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: radial-gradient(circle, var(--accent), rgba(16, 185, 129, 0));
  animation: core-flash 0.7s ease 0.3s both;
}

@keyframes core-flash {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.6); opacity: 1; }
  100% { transform: scale(0.4); opacity: 0; }
}

/* ---- 状态 3：解密完成 ---- */
.card-topic {
  font-size: 24rpx;
  color: var(--accent);
  margin-bottom: 16rpx;
  font-family: "SF Mono", "Consolas", monospace;
}

/* 实名直发：发言人头部，蓝色系与匿名绿色形成区分 */
.realname-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.rn-badge {
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: #ffffff;
  background: #3b82f6;
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
  font-family: "SF Mono", "Consolas", monospace;
}

.rn-name {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.card-body {
  font-size: 30rpx;
  line-height: 1.6;
  letter-spacing: 1rpx;
  color: var(--text);
  word-break: break-word;
}

.card.decrypted {
  animation: reveal 0.5s ease both;
}

@keyframes reveal {
  0% { opacity: 0; transform: translateY(8rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

.trust-tag {
  display: inline-block;
  margin-top: 20rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  color: var(--accent);
  border: 1rpx solid var(--accent);
  border-radius: 8rpx;
  background: rgba(16, 185, 129, 0.08);
  font-family: "SF Mono", "Consolas", monospace;
  letter-spacing: 1rpx;
}

.trust-tag.bad {
  color: #ef4444;
  border-color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
}

.card-footer {
  display: flex;
  gap: 36rpx;
  margin-top: 24rpx;
}

.action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--aux);
}

.action.on { color: var(--accent); }
.action .icon { font-size: 30rpx; }

/* ===================== Zone 2 ===================== */

.zone-2 {
  flex: 0 0 auto;
  transition: all 0.32s ease;
}

.health-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  font-size: 24rpx;
  color: var(--aux);
  border-top: 1rpx solid var(--border);
  border-bottom: 1rpx solid var(--border);
  background: var(--card);
}

.health-bar .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 12rpx var(--accent);
}

.glass-panel {
  position: relative;
  margin: 16rpx 24rpx;
  padding: 28rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(16, 185, 129, 0.10);
  border: 1rpx solid rgba(16, 185, 129, 0.25);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.glass-hint {
  display: block;
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--aux);
  letter-spacing: 1rpx;
}

/* 碎纸散开动效：4 路 hex 粒子从中心飞向四周 */
.shred-stage {
  position: relative;
  height: 112rpx;
}

.shred-particle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 26rpx;
  color: var(--accent);
  font-family: "SF Mono", "Consolas", monospace;
  font-weight: 600;
  text-shadow: 0 0 16rpx rgba(16, 185, 129, 0.7);
  animation: shred-fly 1s cubic-bezier(0.3, 0, 0.2, 1) both;
}

@keyframes shred-fly {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
  15% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  100% {
    opacity: 0;
    transform: translate(calc(-50% + var(--dx)), calc(-50% + var(--dy))) scale(0.5);
  }
}

/* ===================== Zone 3 ===================== */

.zone-3 {
  flex: 0 0 auto;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border);
  background: var(--card);
}

.anon-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.anon-label {
  font-size: 26rpx;
  color: var(--text);
  letter-spacing: 1rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.img-btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  font-size: 32rpx;
  background: var(--bg);
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
}

.card-image {
  width: 100%;
  border-radius: 16rpx;
  margin: 4rpx 0;
  display: block;
}

.voice-btn {
  flex: 0 0 auto;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: var(--text);
  background: var(--bg);
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
}

.voice-btn.recording {
  color: #04110c;
  background: var(--accent);
  border-color: var(--accent);
  box-shadow: 0 0 24rpx rgba(16, 185, 129, 0.5);
}

.text-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text);
  background: var(--bg);
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
}

.send-btn {
  flex: 0 0 auto;
  padding: 20rpx 36rpx;
  font-size: 28rpx;
  color: #04110c;
  background: var(--accent);
  border-radius: 24rpx;
  box-shadow: 0 0 20rpx rgba(16, 185, 129, 0.35);
}
